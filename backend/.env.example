DATABASE_URL=postgresql://user:pass@localhost:5432/blueocean

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_SES_FROM_ADDRESS=outreach@yourdomain.com
# ARN of the SNS topic that forwards SES inbound emails to the reply webhook.
# Required in production — webhook rejects messages from any other topic.
SNS_TOPIC_ARN=arn:aws:sns:ap-southeast-1:ACCOUNT_ID:ses-inbound-replies

ANTHROPIC_API_KEY=

SNOVIO_CLIENT_ID=
SNOVIO_CLIENT_SECRET=

# Tavily — used by services/sourceRegistry to auto-discover scrape sources
# from whitelisted government directories on campaign create + manual refresh.
TAVILY_API_KEY=

# Enrichment pipeline (PRD §5.4)
# Cowork = Claude for Chrome browser agent (primary). Snov.io is the fallback.
COWORK_DAILY_RUN_CAP=100
ENRICHMENT_DAILY_RUN_CAP=200
ENRICHED_LEADS_PATH=./data/enriched_leads.ndjson

CRAWL4AI_BASE_URL=http://localhost:11235

NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Browser origins allowed to call the API (CORS). Comma-separated for multiple.
# Defaults to http://localhost:3000 for local dev; REQUIRED in production — set
# it to the deployed frontend origin(s), e.g. https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000

# Must match AUTH_SECRET in the frontend .env.local — used to verify backend tokens.
AUTH_SECRET=

# Set to true to skip the actual SES send and write email_events as if sent.
# Remove or set to false when testing with real AWS credentials.
SES_DRY_RUN=true
